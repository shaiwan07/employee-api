# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3307
DB_USER=ltraffic
DB_PASS=LTraffic2024!
DB_NAME=lt_employee

# JWT
JWT_SECRET=ltraffic_jwt_secret_2024_employees_area
JWT_EXPIRES_IN=8h

# File Storage
# FILES_BASE_URL — public URL that the mobile app uses to load images and documents.
#   Development : http://localhost:3000  (Node.js serves the dev-files folder locally)
#   Production  : https://ltraffic.co.uk/employeesarea  (Apache serves the PHP web directory)
FILES_BASE_URL=http://localhost:3000

# UPLOADS_ROOT — absolute filesystem path where uploaded files are written.
#   Development : ./dev-files  (local folder, served by Node.js at '/')
#   Production  : /var/www/vhosts/ltraffic.co.uk/httpdocs/employeesarea
#                 (same directory the PHP web app uses — files are shared)
UPLOADS_ROOT=./dev-files

MAX_FILE_SIZE=10485760
